{
  "name": "mezon-automation",
  "version": "1.0.0",
  "description": "Automation Framework with Playwright + Page Object Model",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",
    "test:standalone": "npx playwright test --config=playwright.auth.config.ts",
    "test:standalone:headed": "npx playwright test --config=playwright.auth.config.ts --headed",
    "test:auth": "npx playwright test --config=playwright.auth.config.ts",
    "test:auth:headed": "npx playwright test --config=playwright.auth.config.ts --headed",
    "test:main": "npx playwright test --config=playwright.config.ts",
    "test:main:headed": "npx playwright test --config=playwright.config.ts --headed",
    "report": "npx playwright show-report",
    "install:browsers": "npx playwright install",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "clean": "rm -rf test-results/ playwright-report/ coverage/"
  },
  "keywords": ["playwright", "automation", "testing", "page-object-model"],
  "author": "Mezon Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0",
    "dotenv": "^16.4.5"
  }
}