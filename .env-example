# Environment Configuration
# Copy file này thành .env và điền thông tin thực tế

# Test Environment (local, dev, staging, prod)
TEST_ENV=local

# Base URLs
BASE_URL=https://dev-mezon.nccsoft.vn
API_URL=https://dev-mezon.nccsoft.vn/api

# Development Environment Credentials
DEV_ADMIN_EMAIL=admin@mezon-dev.test
DEV_ADMIN_PASSWORD=DevAdmin123!
DEV_USER_EMAIL=user@mezon-dev.test  
DEV_USER_PASSWORD=DevUser123!

# Staging Environment Credentials
STAGING_ADMIN_EMAIL=admin@mezon-staging.test
STAGING_ADMIN_PASSWORD=
STAGING_USER_EMAIL=user@mezon-staging.test
STAGING_USER_PASSWORD=

# Production Environment Credentials (CI only)
PROD_ADMIN_EMAIL=
PROD_ADMIN_PASSWORD=
PROD_USER_EMAIL=
PROD_USER_PASSWORD=

# CI Configuration
CI=false
NOTIFICATION_WEBHOOK=

# Test Configuration
HEADLESS=true
BROWSER=chromium
WORKERS=1
RETRIES=2

# Reporting
ALLURE_RESULTS_DIR=allure-results
HTML_REPORT_DIR=reports/html

DB_HOST=localhost
DB_PORT=5432
DB_NAME=mezon_test
DB_USER=test
DB_PASSWORD=test